# Normalizar saltos de línea al hacer checkout
* text=auto

# Scripts de Maven Wrapper: LF en Unix, CRLF en Windows
mvnw        text eol=lf
*.cmd       text eol=crlf
*.bat       text eol=crlf

# Scripts de shell siempre LF
*.sh        text eol=lf

# Archivos Java y configuración
*.java      text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.properties text eol=lf
*.json      text eol=lf

# Frontend
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.css       text eol=lf
*.html      text eol=lf

# Binarios: no tocar
*.jar       binary
*.png       binary
*.jpg       binary
*.gif       binary
*.ico       binary
*.zip       binary
