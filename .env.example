# =============================================
# SANOS Y SALVOS — Variables de entorno locales
# Copia este archivo como .env y rellena los valores
# NUNCA subas el .env al repositorio
# =============================================

# ---- Base de datos ----
POSTGRES_USER=sanossalvos
POSTGRES_PASSWORD=sanossalvos
POSTGRES_DB=sanossalvos
POSTGRES_PORT=5432

# ---- JWT (ms-user-auth) ----
JWT_SECRET=cambia_esta_clave_secreta_por_una_de_al_menos_256_bits
JWT_EXPIRATION_MS=86400000

# ---- Correo (ms-notification) ----
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_app_password_de_gmail

# ---- Puertos (referencia, no modificar sin actualizar docker-compose) ----
PORT_GATEWAY=8080
PORT_PET=8081
PORT_GEO=8082
PORT_MATCHING=8083
PORT_AUTH=8084
PORT_NOTIFICATION=8085
PORT_BFF=8086
PORT_FRONTEND=5173
