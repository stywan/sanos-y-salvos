# ============================================================
#  Variables de entorno — Sanos y Salvos
#  Copia este archivo como .env y ajusta los valores:
#  cp .env.example .env
# ============================================================

# ── JWT ──────────────────────────────────────────────────────
# OBLIGATORIO en producción: mínimo 32 caracteres aleatorios
JWT_SECRET=clave_local_desarrollo_no_usar_en_produccion

# ── Correo (ms-notification) ─────────────────────────────────
# Configura con tu cuenta SMTP real para que los emails funcionen
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu-correo@gmail.com
MAIL_PASSWORD=tu-app-password-de-gmail
